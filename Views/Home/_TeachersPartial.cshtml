@model DrivingSchoolWeb.Models.LandingPageViewModel
@{
    var apiBase = ViewBag.ApiBaseUrl ?? "http://103.90.225.223:8080";
}
<section class="py-16 md:py-24 bg-surface-container-low" id="teachers-section">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-12 md:mb-16">
        <div class="section-ribbon-wrapper" data-aos="zoom-in">
            <div class="section-ribbon">
                <span>ĐỘI NGŨ GIÁO VIÊN</span>
            </div>
        </div>
        <p class="text-on-surface-variant max-w-2xl mx-auto text-center mt-4" data-aos="fade-up" data-aos-delay="100">Kinh nghiệm dày dặn, tận tâm với từng học viên</p>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        @if (Model.Teachers.Any())
        {
            <div class="flex flex-wrap justify-center gap-8 md:gap-12">
                @foreach (var teacher in Model.Teachers)
                {
                    var imgSrc = !string.IsNullOrEmpty(teacher.Image) ? $"{apiBase}{teacher.Image}" : "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400";
                    <div class="text-center group" data-aos="zoom-in" data-aos-delay="@(Model.Teachers.ToList().IndexOf(teacher) * 100)">
                        <div class="w-40 h-40 mx-auto rounded-full overflow-hidden shadow-xl mb-6 border-4 border-white group-hover:border-primary transition-colors teacher-glow">
                            <img class="w-full h-full object-cover" alt="@teacher.Name" src="@imgSrc" />
                        </div>
                        <h3 class="text-xl font-black mb-2">@teacher.Name</h3>
                        <p class="text-on-surface-variant text-sm leading-relaxed px-4">@teacher.Description</p>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-12 text-on-surface-variant">
                <span class="material-symbols-outlined text-5xl mb-4 block">group</span>
                <p>Đang cập nhật thông tin giáo viên...</p>
            </div>
        }
    </div>
</section>
