@model DrivingSchoolWeb.Models.LandingPageViewModel
@using System.Text.Json
@{
    var apiBase = ViewBag.ApiBaseUrl ?? "http://103.90.225.223:8080";

    var aboutText1 = Model.Settings.GetValueOrDefault("about_text_1", "Tại trung tâm, chúng tôi không chỉ dừng lại ở việc giúp học viên thi đậu lấy bằng mà còn là hành trang kiến thức vững vàng trên mọi nẻo đường.");
    var aboutText2 = Model.Settings.GetValueOrDefault("about_text_2", "Với đội ngũ giáo viên trên 10 năm kinh nghiệm, tận tâm, chúng tôi cam kết mang lại trải nghiệm học tập tốt nhất, an toàn và hiệu quả.");

    var featuresJson = Model.Settings.GetValueOrDefault("about_features", "[]");
    List<dynamic> features = new List<dynamic>();
    try {
        features = JsonSerializer.Deserialize<List<dynamic>>(featuresJson);
    } catch { }
}
<section class="py-16 md:py-24 bg-white overflow-hidden" id="about">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Toast Messages -->
        @if (TempData["LeadSuccess"] != null)
        {
            <div class="toast-message toast-success"> @TempData["LeadSuccess"]</div>
        }
        @if (TempData["LeadError"] != null)
        {
            <div class="toast-message toast-error"> @TempData["LeadError"]</div>
        }

        <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 items-start" id="registration-form">
            <!-- Cột trái: Về chúng tôi -->
            <div class="lg:w-1/2" data-aos="fade-right">
                <h2 class="text-3xl md:text-4xl font-black text-on-surface mb-2 leading-[1.2] tracking-normal">
                    Về <span class="text-primary italic">Chúng Tôi</span>
                </h2>
                <div class="w-16 h-1.5 bg-primary mb-6 rounded-full"></div>
                <p class="text-base text-on-surface-variant mb-4 leading-relaxed">@aboutText1</p>
                <p class="text-base text-on-surface-variant mb-8 leading-relaxed">@aboutText2</p>
                <div class="space-y-4">
                    @foreach (var feature in features)
                    {
                        var dict = JsonSerializer.Deserialize<Dictionary<string, string>>(feature.ToString());
                        <div class="flex items-start gap-3">
                            <span class="material-symbols-outlined text-primary mt-0.5" style="font-size:20px;">check_circle</span>
                            <div>
                                <h4 class="font-bold text-sm">@dict["title"]</h4>
                                <p class="text-xs text-on-surface-variant">@dict["desc"]</p>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Cột phải: Form đăng ký -->
            <div class="lg:w-1/2 w-full" data-aos="fade-left">
                <div class="bg-white rounded-2xl shadow-xl p-6 md:p-8">
                    <form asp-action="SubmitLead" asp-controller="Home" method="post" class="space-y-5">
                        @Html.AntiForgeryToken()
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                            <div class="space-y-1.5">
                                <label class="text-sm font-bold text-on-surface-variant">Họ và tên *</label>
                                <input name="Full_name" required
                                       class="w-full bg-surface-container border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary focus:bg-white transition-all"
                                       placeholder="Nguyễn Văn A" type="text" />
                            </div>
                            <div class="space-y-1.5">
                                <label class="text-sm font-bold text-on-surface-variant">Số điện thoại *</label>
                                <input name="Phone" required
                                       class="w-full bg-surface-container border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary focus:bg-white transition-all"
                                       placeholder="0901 234 XXX" type="tel" />
                            </div>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                            <div class="space-y-1.5">
                                <label class="text-sm font-bold text-on-surface-variant">Email</label>
                                <input name="Email"
                                       class="w-full bg-surface-container border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary focus:bg-white transition-all"
                                       placeholder="email@example.com" type="email" />
                            </div>
                            <div class="space-y-1.5">
                                <label class="text-sm font-bold text-on-surface-variant">Địa chỉ</label>
                                <input name="Address"
                                       class="w-full bg-surface-container border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary focus:bg-white transition-all"
                                       placeholder="Quận/Huyện, Tỉnh/TP" type="text" />
                            </div>
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-sm font-bold text-on-surface-variant">Khóa học quan tâm</label>
                            <select name="Course_interested_id"
                                    class="w-full bg-surface-container border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary focus:bg-white transition-all appearance-none">
                                <option value="">-- Chọn khóa học --</option>
                                @foreach (var course in Model.CoursesForForm)
                                {
                                    <option value="@course.Id">@course.Name</option>
                                }
                            </select>
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-sm font-bold text-on-surface-variant">Ghi chú</label>
                            <textarea name="Customer_notes"
                                      class="w-full bg-surface-container border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary focus:bg-white transition-all"
                                      placeholder="Bạn cần tư vấn thêm điều gì?" rows="3"></textarea>
                        </div>
                        <button class="w-full red-gradient text-white py-3.5 rounded-xl font-bold text-base shadow-lg active:scale-[0.98] transition-all" type="submit">
                            Gửi yêu cầu tư vấn
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
