@model DrivingSchoolWeb.Models.LandingPageViewModel
@using System.Text.Json
@{
    var apiBase = ViewBag.ApiBaseUrl ?? "http://103.90.225.223:8080";
    var settings = Model.Settings ?? new Dictionary<string, string>();

    var aboutText1 = settings.GetValueOrDefault("about_text_1", "Tại trung tâm, chúng tôi không chỉ dừng lại ở việc giúp học viên thi đậu lấy bằng mà còn là hành trang kiến thức vững vàng trên mọi nẻo đường.");
    var aboutText2 = settings.GetValueOrDefault("about_text_2", "Với đội ngũ giáo viên trên 10 năm kinh nghiệm, tận tâm, chúng tôi cam kết mang lại trải nghiệm học tập tốt nhất, an toàn và hiệu quả.");

    var featuresJson = settings.GetValueOrDefault("about_features", "[]");
    List<dynamic> features = new List<dynamic>();
    try {
        features = JsonSerializer.Deserialize<List<dynamic>>(featuresJson);
    } catch { }
}
<section class="py-16 md:py-24 bg-white overflow-hidden" id="about">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Toast Messages -->
        @if (TempData["LeadSuccess"] != null)
        {
            <div class="toast-message toast-success"> @TempData["LeadSuccess"]</div>
        }
        @if (TempData["LeadError"] != null)
        {
            <div class="toast-message toast-error"> @TempData["LeadError"]</div>
        }

        <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 items-start" id="registration-form">
            <!-- Cột trái: Về chúng tôi -->
            <div class="lg:w-1/2" data-aos="fade-right">
                <h2 class="text-3xl md:text-4xl font-black text-on-surface mb-2 leading-[1.2] tracking-normal">
                    Về <span class="text-primary italic">Chúng Tôi</span>
                </h2>
                <div class="w-16 h-1.5 bg-primary mb-6 rounded-full"></div>
                <p class="text-base text-on-surface-variant mb-4 leading-relaxed">@aboutText1</p>
                <p class="text-base text-on-surface-variant mb-8 leading-relaxed">@aboutText2</p>
                <div class="space-y-4">
                    @foreach (var feature in features)
                    {
                        var dict = JsonSerializer.Deserialize<Dictionary<string, string>>(feature.ToString());
                        @if (dict != null)
                        {
                            <div class="flex items-start gap-3">
                                <span class="material-symbols-outlined text-primary mt-0.5" style="font-size:20px;">check_circle</span>
                                <div>
                                    <h4 class="font-bold text-sm">@dict["title"]</h4>
                                    <p class="text-xs text-on-surface-variant">@dict["desc"]</p>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>

            <!-- Cột phải: Form đăng ký -->
            <div class="lg:w-1/2 w-full" data-aos="fade-left">
                <div class="bg-white rounded-2xl shadow-xl p-6 md:p-8">
                    <form asp-action="SubmitLead" asp-controller="Home" method="post" class="space-y-5">
                        @Html.AntiForgeryToken()
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                            <div class="space-y-1.5">
                                <label class="text-sm font-bold text-on-surface-variant">Họ và tên *</label>
                                <input name="Full_name" required
                                       class="w-full bg-surface-container border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary focus:bg-white transition-all"
                                       placeholder="Nguyễn Văn A" type="text" />
                            </div>
                            <div class="space-y-1.5">
                                <label class="text-sm font-bold text-on-surface-variant">Số điện thoại *</label>
                                <input name="Phone" required
                                       class="w-full bg-surface-container border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary focus:bg-white transition-all"
                                       placeholder="0901 234 XXX" type="tel" />
                            </div>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                            <div class="space-y-1.5">
                                <label class="text-sm font-bold text-on-surface-variant">Email</label>
                                <input name="Email"
                                       class="w-full bg-surface-container border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary focus:bg-white transition-all"
                                       placeholder="email@example.com" type="email" />
                            </div>
                            <div class="space-y-1.5">
                                <label class="text-sm font-bold text-on-surface-variant">Địa chỉ</label>
                                <input name="Address"
                                       class="w-full bg-surface-container border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary focus:bg-white transition-all"
                                       placeholder="Quận/Huyện, Tỉnh/TP" type="text" />
                            </div>
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-sm font-bold text-on-surface-variant">Khóa học quan tâm</label>
                            <select id="course-select" name="Course_interested_id"
                                    class="w-full bg-surface-container border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary focus:bg-white transition-all appearance-none">
                                <option value="">-- Chọn khóa học --</option>
                                @foreach (var course in Model.CoursesForForm)
                                {
                                    <option value="@course.Id">@course.Name</option>
                                }
                            </select>
                        </div>

                        <!-- Hidden Input for Voucher Code -->
                        <input type="hidden" id="applied-voucher-code-input" name="Applied_voucher_code" value="" />

                        <!-- Voucher list & Price calculation area -->
                        <div id="voucher-pricing-area" class="hidden space-y-4 border border-dashed border-primary/30 rounded-2xl p-4 bg-primary/5 animate-fadeIn">
                            <!-- Voucher list -->
                            <div class="space-y-2">
                                <label class="text-sm font-bold text-on-surface-variant flex items-center gap-1.5">
                                    <span class="material-symbols-outlined text-sm text-primary">local_activity</span>
                                    Chọn mã giảm giá khả dụng:
                                </label>
                                <div id="voucher-list-options" class="flex flex-wrap gap-2">
                                    <!-- Populated dynamically by JS -->
                                </div>
                            </div>

                            <!-- Price calculation detail -->
                            <div class="border-t border-primary/10 pt-3 flex flex-col gap-1.5 text-sm">
                                <div class="flex justify-between">
                                    <span class="text-gray-500">Học phí gốc:</span>
                                    <span id="calc-original-price" class="font-semibold text-gray-700">0đ</span>
                                </div>
                                <div id="calc-discount-row" class="flex justify-between text-red-600 hidden">
                                    <span class="font-semibold">Mã giảm giá áp dụng (<span id="active-voucher-code-label"></span>):</span>
                                    <span id="calc-discount-value" class="font-extrabold">-0đ</span>
                                </div>
                                <div class="flex justify-between items-center border-t border-primary/10 pt-2">
                                    <span class="font-bold text-on-surface">Học phí sau ưu đãi:</span>
                                    <span id="calc-final-price" class="text-xl font-black text-red-600">0đ</span>
                                </div>
                            </div>
                        </div>

                        <div class="space-y-1.5">
                            <label class="text-sm font-bold text-on-surface-variant">Ghi chú</label>
                            <textarea name="Customer_notes"
                                      class="w-full bg-surface-container border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary focus:bg-white transition-all"
                                      placeholder="Bạn cần tư vấn thêm điều gì?" rows="3"></textarea>
                        </div>
                        <button class="w-full red-gradient text-white py-3.5 rounded-xl font-bold text-base shadow-lg active:scale-[0.98] transition-all" type="submit">
                            Gửi yêu cầu tư vấn
                        </button>

                        <!-- Client-side script to calculate pricing and display eligible vouchers -->
                        <script>
                            document.addEventListener("DOMContentLoaded", function () {
                                const vouchers = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Vouchers));
                                const courses = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CoursesForForm));
                                console.log("Vouchers:", vouchers);
                                console.log("Courses:", courses);

                                const courseSelect = document.getElementById("course-select");
                                const voucherPricingArea = document.getElementById("voucher-pricing-area");
                                const voucherListOptions = document.getElementById("voucher-list-options");
                                const calcOriginalPrice = document.getElementById("calc-original-price");
                                const calcDiscountRow = document.getElementById("calc-discount-row");
                                const activeVoucherCodeLabel = document.getElementById("active-voucher-code-label");
                                const calcDiscountValue = document.getElementById("calc-discount-value");
                                const calcFinalPrice = document.getElementById("calc-final-price");
                                const appliedVoucherInput = document.getElementById("applied-voucher-code-input");

                                let selectedCourse = null;
                                let selectedVoucher = null;

                                function formatMoney(amount) {
                                    return new Intl.NumberFormat('vi-VN').format(amount) + 'đ';
                                }

                                function updatePrices() {
                                    if (!selectedCourse) {
                                        voucherPricingArea.classList.add("hidden");
                                        appliedVoucherInput.value = "";
                                        return;
                                    }

                                    const originalPrice = selectedCourse.Price || 0;
                                    calcOriginalPrice.innerText = formatMoney(originalPrice);

                                    if (selectedVoucher) {
                                        const discountPercent = selectedVoucher.Discount || 0;
                                        const discountAmount = Math.round(originalPrice * (discountPercent / 100));
                                        const finalPrice = originalPrice - discountAmount;

                                        activeVoucherCodeLabel.innerText = selectedVoucher.Code;
                                        calcDiscountValue.innerText = `-${formatMoney(discountAmount)} (-${discountPercent}%)`;
                                        calcDiscountRow.classList.remove("hidden");
                                        calcFinalPrice.innerText = formatMoney(finalPrice);
                                        appliedVoucherInput.value = selectedVoucher.Code;
                                    } else {
                                        calcDiscountRow.classList.add("hidden");
                                        calcFinalPrice.innerText = formatMoney(originalPrice);
                                        appliedVoucherInput.value = "";
                                    }

                                    voucherPricingArea.classList.remove("hidden");
                                }

                                function renderVouchers(courseId) {
                                    voucherListOptions.innerHTML = "";
                                    selectedVoucher = null;

                                    // Filter active vouchers that apply to this course or all courses
                                    const applicableVouchers = vouchers.filter(v => 
                                        v.Status && 
                                        (v.Course_ids.length === 0 || v.Course_ids.includes(courseId))
                                    );

                                    if (applicableVouchers.length === 0) {
                                        voucherListOptions.innerHTML = `<span class="text-xs text-gray-500 italic">Không có mã giảm giá nào phù hợp cho khóa học này.</span>`;
                                        return;
                                    }

                                    applicableVouchers.forEach(v => {
                                        const btn = document.createElement("button");
                                        btn.type = "button";
                                        btn.className = "flex items-center gap-1.5 px-3 py-1.5 rounded-xl border-2 border-gray-200 bg-white text-xs font-bold text-gray-700 hover:border-red-500 hover:bg-red-50 transition-all cursor-pointer";
                                        btn.innerHTML = `
                                            <span class="font-mono text-red-600">${v.Code}</span>
                                            <span class="bg-red-500 text-white px-1.5 py-0.5 rounded text-[10px]">-${v.Discount}%</span>
                                        `;

                                        btn.addEventListener("click", function() {
                                            // Deselect previous
                                            const prevActive = voucherListOptions.querySelector(".border-red-500");
                                            if (prevActive === btn) {
                                                // Click again to toggle off
                                                btn.className = "flex items-center gap-1.5 px-3 py-1.5 rounded-xl border-2 border-gray-200 bg-white text-xs font-bold text-gray-700 hover:border-red-500 hover:bg-red-50 transition-all cursor-pointer";
                                                selectedVoucher = null;
                                            } else {
                                                if (prevActive) {
                                                    prevActive.className = "flex items-center gap-1.5 px-3 py-1.5 rounded-xl border-2 border-gray-200 bg-white text-xs font-bold text-gray-700 hover:border-red-500 hover:bg-red-50 transition-all cursor-pointer";
                                                }
                                                btn.className = "flex items-center gap-1.5 px-3 py-1.5 rounded-xl border-2 border-red-500 bg-red-50/50 text-xs font-bold text-gray-800 hover:border-red-500 transition-all cursor-pointer shadow-sm";
                                                selectedVoucher = v;
                                            }
                                            updatePrices();
                                        });

                                        voucherListOptions.appendChild(btn);
                                    });
                                }

                                courseSelect.addEventListener("change", function () {
                                    const courseId = parseInt(this.value);
                                    selectedCourse = courses.find(c => c.Id === courseId) || null;

                                    if (selectedCourse) {
                                        renderVouchers(courseId);
                                    }
                                    updatePrices();
                                });
                            });
                        </script>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>