@model DrivingSchoolWeb.Models.LandingPageViewModel
<section class="py-16 md:py-24 bg-surface relative overflow-hidden">
    <div class="floating-dots"><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="fade-up stagger-1 card-lift bg-surface-container-lowest p-6 md:p-10 rounded-2xl shadow-sm flex flex-col justify-between min-h-56 md:h-64 border-l-4 border-primary">
                <div class="stat-number text-5xl font-black text-on-surface text-editorial" data-count="5000" data-suffix="+">0</div>
                <div>
                    <h3 class="text-xl font-bold text-on-surface mb-2">Học viên tin tưởng</h3>
                    <p class="text-on-surface-variant leading-relaxed">Cộng đồng học viên trải dài khắp cả nước, đánh giá cao chất lượng đào tạo.</p>
                </div>
            </div>
            <div class="fade-up stagger-2 red-gradient p-6 md:p-10 rounded-2xl shadow-sm flex flex-col justify-between min-h-56 md:h-64 text-white">
                <div class="stat-number text-5xl font-black text-editorial" data-count="98" data-suffix="%">0</div>
                <div>
                    <h3 class="text-xl font-bold mb-2">Tỉ lệ đậu sát hạch</h3>
                    <p class="text-white/80 leading-relaxed">Quy trình đào tạo tối ưu giúp học viên tự tin vượt qua mọi kỳ thi ngay lần đầu.</p>
                </div>
            </div>
            <div class="fade-up stagger-3 card-lift bg-surface-container-lowest p-6 md:p-10 rounded-2xl shadow-sm flex flex-col justify-between min-h-56 md:h-64 border-l-4 border-primary">
                <div class="stat-number text-5xl font-black text-on-surface text-editorial" data-count="10" data-suffix="+">0</div>
                <div>
                    <h3 class="text-xl font-bold text-on-surface mb-2">Năm kinh nghiệm</h3>
                    <p class="text-on-surface-variant leading-relaxed">Khẳng định vị thế dẫn đầu trong lĩnh vực đào tạo và sát hạch lái xe chuyên nghiệp.</p>
                </div>
            </div>
        </div>
    </div>
</section>
