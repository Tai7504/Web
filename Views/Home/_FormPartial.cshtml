@model DrivingSchoolWeb.Models.LandingPageViewModel
@{
    var phone = Model.Settings.GetValueOrDefault("hotline", "0939 360 123 - 0962 034 148");
    var email = Model.Settings.GetValueOrDefault("email", "hoangban57@gmail.com");
    var address = Model.Settings.GetValueOrDefault("address", "DX70 - Khu Phố 5 - Định Hòa - Thủ Dầu Một - Bình Dương");
}
<section class="py-16 md:py-24 bg-surface relative" id="registration-form">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <!-- Toast Messages -->
        @if (TempData["LeadSuccess"] != null)
        {
            <div class="toast-message toast-success"> @TempData["LeadSuccess"]</div>
        }
        @if (TempData["LeadError"] != null)
        {
            <div class="toast-message toast-error"> @TempData["LeadError"]</div>
        }
        <!-- Tiêu đề section -->
        <div class="text-center mb-14 fade-up">
            <h2 class="text-4xl md:text-5xl font-black text-on-surface mb-4">Đăng Ký <span class="text-primary">Tư Vấn</span></h2>
            <div class="w-16 h-1.5 bg-primary mx-auto mb-6 rounded-full"></div>
            <p class="text-on-surface-variant max-w-xl mx-auto">Để lại thông tin, đội ngũ chuyên viên sẽ liên hệ tư vấn lộ trình phù hợp nhất trong 15 phút</p>
        </div>
        <div class="gradient-border-wrap scale-in">
        <div class="bg-white rounded-[2rem] shadow-2xl overflow-hidden flex flex-col md:flex-row">
            <div class="md:w-2/5 red-gradient p-8 md:p-12 text-white">
                <h3 class="text-3xl font-black mb-6 leading-tight">Sẵn sàng để bắt đầu?</h3>
                <p class="text-white/80 mb-10 leading-relaxed">Điền thông tin và chuyên viên của chúng tôi sẽ liên hệ tư vấn lộ trình học phù hợp nhất.</p>
                <div class="space-y-6">
                    <div class="flex items-center gap-4">
                        <span class="material-symbols-outlined">call</span>
                        <span class="font-bold">@phone</span>
                    </div>
                    <div class="flex items-center gap-4">
                        <span class="material-symbols-outlined">mail</span>
                        <span class="font-bold">@email</span>
                    </div>
                    <div class="flex items-center gap-4">
                        <span class="material-symbols-outlined">location_on</span>
                        <span class="font-bold">@address</span>
                    </div>
                </div>
            </div>
            <div class="md:w-3/5 p-8 md:p-12">
                <form asp-action="SubmitLead" asp-controller="Home" method="post" class="space-y-6">
                    @Html.AntiForgeryToken()
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-on-surface-variant">Họ và tên *</label>
                            <input name="Full_name" required
                                   class="w-full bg-surface-container border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary focus:bg-white transition-all"
                                   placeholder="Nguyễn Văn A" type="text" />
                        </div>
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-on-surface-variant">Số điện thoại *</label>
                            <input name="Phone" required
                                   class="w-full bg-surface-container border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary focus:bg-white transition-all"
                                   placeholder="0901 234 XXX" type="tel" />
                        </div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-on-surface-variant">Email</label>
                            <input name="Email"
                                   class="w-full bg-surface-container border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary focus:bg-white transition-all"
                                   placeholder="email@example.com" type="email" />
                        </div>
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-on-surface-variant">Địa chỉ</label>
                            <input name="Address"
                                   class="w-full bg-surface-container border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary focus:bg-white transition-all"
                                   placeholder="Quận/Huyện, Tỉnh/TP" type="text" />
                        </div>
                    </div>
                    <div class="space-y-2">
                        <label class="text-sm font-bold text-on-surface-variant">Khóa học quan tâm</label>
                        <select name="Course_interested_id"
                                class="w-full bg-surface-container border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary focus:bg-white transition-all appearance-none">
                            <option value="">-- Chọn khóa học --</option>
                            @foreach (var course in Model.CoursesForForm)
                            {
                                <option value="@course.Id">@course.Name</option>
                            }
                        </select>
                    </div>
                    <div class="space-y-2">
                        <label class="text-sm font-bold text-on-surface-variant">Ghi chú</label>
                        <textarea name="Customer_notes"
                                  class="w-full bg-surface-container border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary focus:bg-white transition-all"
                                  placeholder="Bạn cần tư vấn thêm điều gì?" rows="4"></textarea>
                    </div>
                    <button class="w-full red-gradient text-white py-4 rounded-xl font-bold text-lg shadow-lg active:scale-[0.98] transition-all btn-ripple" type="submit">
                        Gửi yêu cầu tư vấn
                    </button>
                </form>
            </div>
        </div>
        </div>
    </div>
</section>
