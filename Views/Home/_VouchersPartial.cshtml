@model DrivingSchoolWeb.Models.LandingPageViewModel
@inject IConfiguration Configuration
@{
    var apiBase = Configuration["ApiSettings:BaseUrl"]?.Replace("/api", "") ?? "http://localhost:8080";
    var activeVouchers = Model.Vouchers?.Where(v => v.Status).ToList() ?? new List<DrivingSchoolWeb.Models.VoucherViewModel>();
}

@if (activeVouchers.Any())
{
    <section class="py-12 bg-surface-container-lowest border-b border-surface-container" id="vouchers-section">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <!-- Carousel Container (Thêm padding trái/phải px-[10%] ở mobile và px-[8%] ở desktop để lộ góc voucher hai bên) -->
            <div class="relative overflow-hidden w-full px-[10%] sm:px-[8%] voucher-carousel-wrapper">
                <!-- Carousel Track (Chuyển động tịnh tiến bằng transform, giảm gap xuống gap-4 = 16px để các voucher gần nhau hơn) -->
                <div id="voucher-carousel" class="flex gap-4 w-full" style="transform: translateX(0);">
                    @foreach (var voucher in activeVouchers)
                    {
                        <div class="flex-shrink-0 w-full sm:w-[calc(50%-8px)] voucher-slide flex justify-center" data-index="@activeVouchers.IndexOf(voucher)" data-aos="fade-up" data-aos-delay="@(activeVouchers.IndexOf(voucher) * 100)">
                            <!-- Ticket Card kiểu mới từ voucher_demo.html -->
                            <div class="flex voucher-card bg-white transition-all hover:shadow-lg hover:-translate-y-1 duration-300 w-full min-h-[150px] font-body-md">
                                <!-- Left Stub (Đỏ tươi + Răng cưa trái + Đường đứt nét phải) -->
                                <div class="ticket-stub">
                                    <!-- SVG Vé Vàng Răng Cưa Cực Xịn -->
                                    <svg class="ticket-yellow-svg w-14 h-20 drop-shadow-md" viewBox="0 0 100 150" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <!-- Thân vé vàng với lỗ khuyết bán nguyệt ở đầu trên và đầu dưới -->
                                        <path d="M 10 0 L 40 0 A 10 10 0 0 1 60 0 L 90 0 A 10 10 0 0 1 100 10 L 100 140 A 10 10 0 0 1 90 150 L 60 150 A 10 10 0 0 1 40 150 L 10 150 A 10 10 0 0 1 0 140 L 0 10 A 10 10 0 0 1 10 0 Z" fill="url(#yellow-grad-@voucher.Code)"/>
                                        <!-- Nét đứt ngăn cách ở 1/3 vé -->
                                        <line x1="8" y1="45" x2="92" y2="45" stroke="#e69d00" stroke-width="2.5" stroke-dasharray="5 4"/>
                                        <!-- Icon vé nhỏ đục lỗ ở phần trên -->
                                        <rect x="35" y="14" width="30" height="18" rx="3" fill="#ff4d4d"/>
                                        <circle cx="42" cy="23" r="1.8" fill="#ffcc00"/>
                                        <circle cx="50" cy="23" r="1.8" fill="#ffcc00"/>
                                        <circle cx="58" cy="23" r="1.8" fill="#ffcc00"/>
                                        <!-- Ký hiệu hoặc số phần trăm chiết khấu -->
                                        <text x="50" y="118" fill="#ff4d4d" font-size="34" font-family="Montserrat, sans-serif" font-weight="900" text-anchor="middle">@voucher.Discount%</text>
                                        <defs>
                                            <linearGradient id="yellow-grad-@voucher.Code" x1="0%" y1="0%" x2="100%" y2="100%">
                                                <stop offset="0%" stop-color="#ffe270" />
                                                <stop offset="100%" stop-color="#f5a600" />
                                            </linearGradient>
                                        </defs>
                                    </svg>
                                </div>
                                <!-- Right Content -->
                                <div class="flex-1 p-4 flex flex-col justify-between bg-white border-y border-r border-gray-100 rounded-r-xl">
                                    <!-- Hàng trên: Mã Coupon nét đứt & Điều kiện -->
                                    <div class="flex items-center justify-between">
                                        <span class="font-mono text-xs font-black px-2.5 py-1 bg-red-50 text-voucher-text-red border border-dashed border-red-300 rounded-md tracking-wider select-all">
                                            @voucher.Code
                                        </span>
                                        @if (!string.IsNullOrEmpty(voucher.Terms))
                                        {
                                            <button onclick="showVoucherTerms('@voucher.Code', '@voucher.Terms')" 
                                                    class="text-voucher-link-blue text-xs hover:underline font-bold transition-colors cursor-pointer bg-transparent border-0 p-0">
                                                Điều kiện
                                            </button>
                                        }
                                    </div>
                                    
                                    <!-- Hàng giữa: Mô tả ngắn gọn -->
                                    <div class="my-2">
                                        <p class="text-voucher-text-gray text-xs sm:text-sm leading-relaxed line-clamp-2">
                                            @voucher.Description
                                        </p>
                                    </div>
                                    
                                    <!-- Hàng dưới: Badge Tự động áp dụng nổi bật với hiệu ứng lấp lánh -->
                                    <div class="flex items-center mt-auto">
                                        <div class="inline-flex items-center gap-1.5 bg-emerald-50 text-emerald-700 border border-emerald-200 px-3 py-1.5 rounded-full text-xs font-bold shadow-xs select-none">
                                            <span class="material-symbols-outlined text-[14px] text-emerald-600 animate-pulse-light">auto_awesome</span>
                                            <span>Tự động áp dụng</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Navigation Indicator Dots (Tương tự Hero banner) -->
                <div class="voucher-carousel-dots" id="voucher-dots" data-aos="fade-up"></div>
            </div>
        </div>
    </section>

    <!-- Visual Modal for Conditions -->
    <div id="voucher-terms-modal" class="fixed inset-0 bg-gray-900 bg-opacity-30 hidden items-center justify-center z-[100] p-4 backdrop-blur-xs transition-opacity duration-300">
        <div class="bg-white rounded-2xl max-w-sm w-full p-6 shadow-2xl relative transform transition-transform duration-300 scale-95" id="voucher-modal-content-box">
            <div class="flex items-center gap-2 text-red-600 mb-3">
                <span class="material-symbols-outlined text-xl">local_activity</span>
                <h4 class="text-lg font-black text-gray-800">Điều kiện áp dụng</h4>
            </div>
            <div class="text-sm font-bold text-gray-900 mb-4 bg-gray-50 border border-gray-200 px-3 py-1.5 rounded-lg flex justify-between items-center">
                <span>Mã giảm giá:</span>
                <span class="font-mono text-red-600" id="terms-modal-code"></span>
            </div>
            <p class="text-sm text-gray-600 leading-relaxed mb-6" id="terms-modal-content"></p>
            <button onclick="closeVoucherTerms()" class="w-full py-3 bg-red-600 hover:bg-red-700 text-white font-bold rounded-xl text-sm transition-colors cursor-pointer active:scale-98 border-0">
                Đóng
            </button>
        </div>
    </div>

    <!-- Toast Notification (Giữ lại để tương thích logic JS copyCode nếu cần gọi) -->
    <div class="fixed bottom-10 left-1/2 -translate-x-1/2 bg-gray-900 text-white px-6 py-3 rounded-full shadow-2xl opacity-0 pointer-events-none transition-all duration-300 z-[100] flex items-center gap-2 border border-gray-800" id="toast-voucher">
        <span class="material-symbols-outlined text-green-400" style="font-variation-settings: 'FILL' 1;">check_circle</span>
        <span class="text-sm font-medium">Đã sao chép mã thành công!</span>
    </div>
}
